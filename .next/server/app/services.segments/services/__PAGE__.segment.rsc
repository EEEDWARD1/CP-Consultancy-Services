2:T95d,{"@context":"https://schema.org","@type":"ItemList","name":"Construction Consultancy Services","url":"https://www.cpconsultancyservice.co.uk/services","itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"Service","name":"Project Management","description":"Acting as project manager to represent the client and employer in the day-to-day management of a project, we will support client as early as possible in the development of the project so that they can ensure the correct structure and systems are in place from the outset. As project manager, we will be primarily responsible for taking your idea and bringing it to life using best practice and professional skills.","provider":{"@type":"ProfessionalService","name":"CP Consultancy Services","url":"https://www.cpconsultancyservice.co.uk"}}},{"@type":"ListItem","position":2,"item":{"@type":"Service","name":"Employer's Agent","description":"We are skilled and effective Employer’s Agents (EA) and are highly experienced across a range of sectors. Acting as Lead Consultant or EA on behalf of the client to deliver JCT Design & Build contracts, we can carry out this service either from the client organisation such as an in-house project manager, or as an independent EA appointed by the client.","provider":{"@type":"ProfessionalService","name":"CP Consultancy Services","url":"https://www.cpconsultancyservice.co.uk"}}},{"@type":"ListItem","position":3,"item":{"@type":"Service","name":"Quantity Surveying","description":"Our experienced and knowledgeable cost management expert understand the importance of delivering a project to meet your budget and financial expectations. We will work with clients to develop aspirations, offer best value for money and maximise budget efficiency.","provider":{"@type":"ProfessionalService","name":"CP Consultancy Services","url":"https://www.cpconsultancyservice.co.uk"}}},{"@type":"ListItem","position":4,"item":{"@type":"Service","name":"Clerk of Works","description":"Employers, Local Authorities and Housing Associations have the challenge of ensuring that their construction projects achieve value for money and are completed to a high quality in terms of workmanship, materials, construction standards and building regulation statutory compliance.","provider":{"@type":"ProfessionalService","name":"CP Consultancy Services","url":"https://www.cpconsultancyservice.co.uk"}}}]}0:{"rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.cpconsultancyservice.co.uk\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.cpconsultancyservice.co.uk/services\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","section",null,{"aria-label":"Project image slideshow","className":"pointer-events-none relative h-[34svh] min-h-60 w-full overflow-hidden","children":["$","$L3",null,{"images":[{"src":"/images/img1.webp","alt":"Image 1"},{"src":"/images/img2.webp","alt":"Image 2"},{"src":"/images/img3.webp","alt":"Image 3"},{"src":"/images/img4.webp","alt":"Image 4"},{"src":"/images/img5.webp","alt":"Image 5"}],"className":"h-full w-full","overlay":true,"priority":true}]}],["$","section",null,{"className":"w-full overflow-x-clip py-16 sm:py-24 lg:py-28 bg-brand-surface","children":"$L4"}]],["$L5"],"$L6"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"7GjRohXrSHhVicGf8xa3B"}
4:["$","div",null,{"className":"mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"mx-auto max-w-4xl","children":[["$","div",null,{"className":"mx-auto max-w-3xl text-center","children":[["$","div",null,{"className":"mx-auto mb-5 h-1 w-16 rounded-full bg-brand-accent"}],["$","h1",null,{"className":"text-balance text-3xl font-semibold leading-tight text-brand-primary sm:text-5xl","children":"Services we provide"}],null]}],["$","div",null,{"className":"mt-12","children":["$","$L7",null,{"items":[{"title":"Project Management","content":["$","div",null,{"className":"space-y-5","children":[["$","p","Acting as project manager to represent the client and employer in the day-to-day management of a project, we will support client as early as possible in the development of the project so that they can ensure the correct structure and systems are in place from the outset. As project manager, we will be primarily responsible for taking your idea and bringing it to life using best practice and professional skills.",{"className":"font-body text-base leading-8 text-brand-muted sm:text-lg","children":"Acting as project manager to represent the client and employer in the day-to-day management of a project, we will support client as early as possible in the development of the project so that they can ensure the correct structure and systems are in place from the outset. As project manager, we will be primarily responsible for taking your idea and bringing it to life using best practice and professional skills."}],["$","p","We will be responsible for the day-today detailed management of the project and provide the interface between the project sponsor and the supplier members of the project team.",{"className":"font-body text-base leading-8 text-brand-muted sm:text-lg","children":"We will be responsible for the day-today detailed management of the project and provide the interface between the project sponsor and the supplier members of the project team."}]]}]},{"title":"Employer's Agent","content":["$","div",null,{"className":"space-y-5","children":[["$","p","We are skilled and effective Employer’s Agents (EA) and are highly experienced across a range of sectors. Acting as Lead Consultant or EA on behalf of the client to deliver JCT Design & Build contracts, we can carry out this service either from the client organisation such as an in-house project manager, or as an independent EA appointed by the client.",{"className":"font-body text-base leading-8 text-brand-muted sm:text-lg","children":"We are skilled and effective Employer’s Agents (EA) and are highly experienced across a range of sectors. Acting as Lead Consultant or EA on behalf of the client to deliver JCT Design & Build contracts, we can carry out this service either from the client organisation such as an in-house project manager, or as an independent EA appointed by the client."}],["$","p","As EA, we also carry out other tasks on the client's behalf prior to the award of a contract, such as employing, forming and managing design team, co-ordinating the tender process, co-ordinating the novation of consultants, collating contract documents for execution and implementing change control procedures. We will represent the client, manage and complete obligations under the contract, and for the contractor to establish correct authorities and instruction from project inception stage towards the end of defect period.",{"className":"font-body text-base leading-8 text-brand-muted sm:text-lg","children":"As EA, we also carry out other tasks on the client's behalf prior to the award of a contract, such as employing, forming and managing design team, co-ordinating the tender process, co-ordinating the novation of consultants, collating contract documents for execution and implementing change control procedures. We will represent the client, manage and complete obligations under the contract, and for the contractor to establish correct authorities and instruction from project inception stage towards the end of defect period."}]]}]},{"title":"Quantity Surveying","content":"$L8"},{"title":"Clerk of Works","content":"$L9"}]}]}]]}]}]
