11:T95d,{"@context":"https://schema.org","@type":"ItemList","name":"Construction Consultancy Services","url":"https://www.cpconsultancyservice.co.uk/services","itemListElement":[{"@type":"ListItem","position":1,"item":{"@type":"Service","name":"Project Management","description":"Acting as project manager to represent the client and employer in the day-to-day management of a project, we will support client as early as possible in the development of the project so that they can ensure the correct structure and systems are in place from the outset. As project manager, we will be primarily responsible for taking your idea and bringing it to life using best practice and professional skills.","provider":{"@type":"ProfessionalService","name":"CP Consultancy Services","url":"https://www.cpconsultancyservice.co.uk"}}},{"@type":"ListItem","position":2,"item":{"@type":"Service","name":"Employer's Agent","description":"We are skilled and effective Employer’s Agents (EA) and are highly experienced across a range of sectors. Acting as Lead Consultant or EA on behalf of the client to deliver JCT Design & Build contracts, we can carry out this service either from the client organisation such as an in-house project manager, or as an independent EA appointed by the client.","provider":{"@type":"ProfessionalService","name":"CP Consultancy Services","url":"https://www.cpconsultancyservice.co.uk"}}},{"@type":"ListItem","position":3,"item":{"@type":"Service","name":"Quantity Surveying","description":"Our experienced and knowledgeable cost management expert understand the importance of delivering a project to meet your budget and financial expectations. We will work with clients to develop aspirations, offer best value for money and maximise budget efficiency.","provider":{"@type":"ProfessionalService","name":"CP Consultancy Services","url":"https://www.cpconsultancyservice.co.uk"}}},{"@type":"ListItem","position":4,"item":{"@type":"Service","name":"Clerk of Works","description":"Employers, Local Authorities and Housing Associations have the challenge of ensuring that their construction projects achieve value for money and are completed to a high quality in terms of workmanship, materials, construction standards and building regulation statutory compliance.","provider":{"@type":"ProfessionalService","name":"CP Consultancy Services","url":"https://www.cpconsultancyservice.co.uk"}}}]}c:["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://www.cpconsultancyservice.co.uk\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Services\",\"item\":\"https://www.cpconsultancyservice.co.uk/services\"}]}"}}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$11"}}],["$","section",null,{"aria-label":"Project image slideshow","className":"pointer-events-none relative h-[34svh] min-h-60 w-full overflow-hidden","children":["$","$L12",null,{"images":[{"src":"/images/img1.webp","alt":"Image 1"},{"src":"/images/img2.webp","alt":"Image 2"},{"src":"/images/img3.webp","alt":"Image 3"},{"src":"/images/img4.webp","alt":"Image 4"},{"src":"/images/img5.webp","alt":"Image 5"}],"className":"h-full w-full","overlay":true,"priority":true}]}],["$","section",null,{"className":"w-full overflow-x-clip py-16 sm:py-24 lg:py-28 bg-brand-surface","children":"$L13"}]],["$L14"],"$L15"]}]
